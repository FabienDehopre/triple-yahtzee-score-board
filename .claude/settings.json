{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/enforce-pnpm.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/no-commit-console-log.mjs"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/check-edit-targets.mjs"
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/check-credentials.mjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/post-lint.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/post-test.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/post-type-check.mjs"
          }
        ]
      }
    ]
  }
}
