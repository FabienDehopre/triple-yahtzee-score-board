{
  "name": "triple-yahtzee-score-board",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.0.4",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "eslint . --fix",
    "e2e": "playwright test",
    "preinstall": "npx only-allow pnpm",
    "prepare": "is-ci || simple-git-hooks"
  },
  "dependencies": {
    "@angular/common": "^21.2.10",
    "@angular/compiler": "^21.2.10",
    "@angular/core": "^21.2.10",
    "@angular/forms": "^21.2.10",
    "@angular/platform-browser": "^21.2.10",
    "@angular/router": "^21.2.10",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.4.10",
    "@analogjs/vitest-angular": "^2.4.10",
    "@angular/build": "^21.2.8",
    "@angular/cli": "^21.2.8",
    "@angular/compiler-cli": "^21.2.10",
    "@fabdeh/eslint-config": "^0.11.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/angular": "^19.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "eslint": "^9.39.4",
    "eslint-plugin-better-tailwindcss": "^4.4.1",
    "eslint-plugin-erasable-syntax-only": "^0.4.1",
    "eslint-plugin-format": "^2.0.1",
    "is-ci": "^4.1.0",
    "jsdom": "^28.1.0",
    "nano-staged": "^1.0.2",
    "postcss": "^8.5.12",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.2.4",
    "typescript": "~5.9.3",
    "vite": "^7.3.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm nano-staged"
  },
  "nano-staged": {
    "*": "eslint --fix --pass-on-no-patterns"
  }
}
